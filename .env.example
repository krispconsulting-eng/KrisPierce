# Copy this file to .env and fill in real values. Never commit .env.
# See docs/CREDENTIALS.md for exactly where to obtain / enter each value.
# Secrets used by n8n nodes live in n8n's own credential vault, NOT in this
# file — this file is only for scripts/services that run outside n8n
# (this repo's scripts/, and n8n's own runtime config).

# --- n8n runtime (self-hosted) ---
N8N_HOST=
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_ENCRYPTION_KEY=          # generate once with: openssl rand -hex 32
N8N_API_KEY=                 # n8n UI > Settings > API > Create API key (used only if scripts call n8n's REST API)

# --- OpenAI (image generation only) ---
OPENAI_API_KEY=

# --- Notion ---
NOTION_API_KEY=              # notion.so/my-integrations > your integration > Internal Integration Secret
NOTION_CLIENTS_DB_ID=
NOTION_CONTENT_CALENDAR_DB_ID=
NOTION_SOPS_DB_ID=

# --- Fathom ---
FATHOM_API_KEY=              # Fathom > Settings > API

# --- Tella ---
TELLA_API_KEY=               # Tella > Settings > Integrations > API / Webhooks
TELLA_WEBHOOK_SECRET=

# --- Gamma ---
GAMMA_API_KEY=               # Gamma workspace > Settings > Developer / API

# --- Blotato ---
BLOTATO_API_KEY=             # Blotato > Settings > API

# --- Windsor AI ---
WINDSOR_API_KEY=             # Windsor AI dashboard > API Access

# --- Flodesk ---
FLODESK_API_KEY=             # Flodesk > Settings > Integrations > API Key (also used by the Flodesk MCP connector)

# --- Apify ---
APIFY_API_TOKEN=             # Apify Console > Settings > Integrations

# Copy this file to .env.local and fill in your Supabase project's values to
# enable real accounts + cross-device sync. Without these set, the app runs
# entirely on local storage (per-browser progress, no account needed) —
# fully functional, just not synced across devices.
#
# Find these in your Supabase project: Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
